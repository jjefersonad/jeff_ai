# PostgreSQL Configuration (pgvector)
POSTGRES_URI=postgresql://postgres:password@localhost:5435/langgraph_dev
DATABASE_URL=postgresql://postgres:password@localhost:5435/langgraph_dev

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=glm-4.6:cloud

# Tavily API (necessário para pesquisa web)
TAVILY_API_KEY=your_tavily_api_key_here

# LangSmith (opcional, para tracing)
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=deep-agent-postgresql
# LANGSMITH_API_KEY=your_langsmith_key_here