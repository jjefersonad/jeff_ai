# PostgreSQL Configuration (pgvector)
POSTGRES_URI=postgresql://postgres:password@localhost:5435/langgraph_dev

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=glm-4.6:cloud

# Tavily API (necessário para pesquisa web)
TAVILY_API_KEY=your_tavily_api_key_here

## Google API Key (adicione sua chave aqui)
GOOGLE_API_KEY=

## OpenRouter configuration (adicione sua chave aqui)
#OPENROUTER_API_KEY=

## OpenAI configuration (adicione sua chave aqui)
# OPENAI_API_KEY=sk-your-openai-api-key-here
# OPENAI_MODEL=gpt-4

# LangSmith (opcional, para tracing)
LANGCHAIN_TRACING_V2=true
LANGSMITH_PROJECT=jeff_ai_project
LANGCHAIN_VERBOSE=true
LANGSMITH_API_KEY=
