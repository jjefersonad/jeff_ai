# Database Configuration (PostgreSQL + pgvector)
POSTGRES_URI=postgresql://jeff_ia:jeff_ia@localhost:5436/jeff_ia

# Senha do Redis (`jeff_ia_redis`, usado internamente pela imagem `langgraph-api`
# para fila/pubsub — nenhum código de aplicação deste repo fala com o Redis
# diretamente). Como POSTGRES_URI acima, o valor REAL não vive aqui: vive no
# `.env` da raiz do projeto (não versionado), que é o arquivo que o
# `docker-compose` usa para resolver `${...}` — inclusive no `command:` do
# serviço `jeff_ia_redis`, que roda fora do container `backend` e não tem
# acesso a `env_file: backend/.env`. Sem essa variável definida, o Redis sobe
# com `--requirepass` vazio (sem autenticação).
REDIS_PASSWORD=

# Origem exata do frontend (protocolo+host+porta). Usada para CORS com
# credenciais: NUNCA "*" quando allow_credentials=true (bloqueado pelos
# navegadores). Lido pelo docker-compose.yml (raiz do projeto, não este
# arquivo) para LANGSERVE_CORS_ALLOW_ORIGINS, e por backend/langgraph.json
# (http.cors.allow_origins) para `langgraph dev`.
FRONTEND_ORIGIN=http://localhost:3002

# Bootstrap do primeiro usuário admin (autenticação por sessão). Usados uma
# única vez, no startup, quando a tabela `users` está vazia. ADMIN_PASSWORD_HASH
# é um hash bcrypt (gerado com passlib), NUNCA a senha em texto plano.
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=minimax-m2.7:cloud
# Janela de contexto do modelo. 8192 estoura com o system prompt + schemas de
# tools atuais (~13.900 tokens estimados); 32768 dá margem. Custa VRAM.
OLLAMA_NUM_CTX=32768

# IANA timezone name. Default: UTC. Exemplo: America/Sao_Paulo
JEFF_AI_TZ=

# Origem pública usada para montar a `url` absoluta retornada pelas tools de
# geração de documento (create_docx_document e afins), servidas hoje pelo
# http.app do backend (src/infrastructure/web/webapp.py), NÃO por
# image_server.py:8080 (aposentado em consolidate-http-routes-langgraph).
# Opcional: se ausente, cai para FRONTEND_ORIGIN e, por fim, para
# http://localhost:3000. Só sete explicitamente se documentos precisarem ser
# servidos de uma origem diferente do frontend (ex.: CDN em produção).
# Em produção/deploy remoto, DEVE apontar para uma origem alcançável pelo
# navegador do usuário final — NUNCA um hostname interno do docker-compose
# (ex.: http://backend:8000), que só resolve dentro da rede docker.
DOCUMENT_BASE_URL=

# Tavily API (web search)
TAVILY_API_KEY=your_tavily_api_key_here

# Google API Keys
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL=gemini-2.5-flash

# OpenRouter (fallback automático quando o Ollama Cloud falha/sem créditos —
# ver src/models/fallback_model.py)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openrouter/free
OPENROUTER_APP_URL=http://localhost:3000
OPENROUTER_APP_TITLE=Jeff AI

# OpenAI (alternative LLM provider)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4

# LangSmith (optional, for tracing)
# NOTE: This key is read by the langgraph SDK at backend startup. The frontend
# no longer reads or writes it; configure it here on the backend only.
LANGCHAIN_TRACING_V2=true
LANGSMITH_PROJECT=jeff_ai_project
LANGCHAIN_VERBOSE=true
LANGSMITH_API_KEY=your_langsmith_api_key_here

# Google API Key (adicione sua chave aqui)
GOOGLE_API_KEY=