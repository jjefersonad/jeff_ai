{
  "_comment": "Copie para mcp_servers.json e edite. NAO e o .mcp.json da raiz do repo (aquele e do Claude Code / OpenSddRag, nao tem relacao com isto). Transportes suportados: 'stdio' (default, exige 'command') e 'http' (streamable HTTP remoto, exige 'url', sem 'command'). Credenciais NUNCA em texto plano aqui -- use ${VAR_NAME}, resolvido de backend/.env, tanto em 'env' (stdio) quanto em 'headers' (http).",
  "mcpServers": {
    "example-server": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-example"],
      "env": {
        "EXAMPLE_API_KEY": "${EXAMPLE_API_KEY}"
      }
    },
    "example-remote-server": {
      "transport": "http",
      "url": "https://example.com/mcp",
      "headers": {
        "Authorization": "${EXAMPLE_REMOTE_TOKEN}"
      }
    }
  }
}
