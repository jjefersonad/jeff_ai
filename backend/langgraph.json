{
  "dependencies": ["."],
  "graphs": {
    "unified": "src.composition.graphs:unified",
    "agent": "src.composition.graphs:agent",
    "sdd_agent": "src.composition.graphs:sdd_agent",
    "assistant": "src.composition.graphs:assistant"
  },
  "http": {
    "app": "./src/infrastructure/web/webapp.py:app",
    "cors": {
      "allow_origins": ["http://localhost:3000"],
      "allow_credentials": true,
      "allow_methods": ["*"],
      "allow_headers": ["*"]
    }
  },
  "auth": {
    "path": "./src/infrastructure/web/auth.py:auth"
  },
  "checkpointer": {
    "type": "postgres",
    "url": "${env:POSTGRES_URI}"
  },
  "store": {
    "type": "postgres",
    "url": "${env:POSTGRES_URI}",
    "index": {
      "embed": "./src/models/ollama_embeddings.py:embed_texts",
      "dims": 1024,
      "fields": ["content"]
    }
  }
}