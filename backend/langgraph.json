{
  "dependencies": ["."],
  "graphs": {
    "agent": "src.agents.requirements_specialist:agent",
    "sdd_agent": "src.agents.sdd.orchestrator:sdd_agent",
    "assistant": "src.agents.assistant:assistant"
  },
  "checkpointer": {
    "type": "postgres",
    "url": "${env:POSTGRES_URI}"
  },
  "store": {
    "type": "postgres",
    "url": "${env:POSTGRES_URI}",
    "index": {
      "embed": "./src/models/ollama_embeddings.py:embed_texts",
      "dims": 1024,
      "fields": ["content"]
    }
  },
  "cors": {
    "allow_origins": ["*"]
  }
}