FROM langchain/langgraph-api:3.11

COPY backend/ /deps/backend/
WORKDIR /deps/backend

# Node/npx para instalação de skills externas (npx skills add) pelo assistant
RUN apt-get update \
    && apt-get install -y --no-install-recommends nodejs npm \
    && rm -rf /var/lib/apt/lists/*

# Install project dependencies (versões fixadas para build reproduzível).
# langgraph-runtime-inmem é reinstalado para satisfazer o langgraph-api 0.10.0 da
# imagem base (evita o warning de dependência órfã após o upgrade do langgraph).
RUN pip install --no-cache-dir \
    "python-dotenv==1.2.2" \
    "wcmatch==10.2.1" \
    "tavily==1.1.0" \
    "deepagents==0.6.12" \
    "langchain-ollama==1.1.0" \
    "langchain-openrouter==0.2.6" \
    "langgraph-runtime-inmem>=0.30.0,<0.31.0" \
    "python-docx==1.2.0" \
    "openpyxl==3.1.5" \
    "python-pptx==1.0.2" \
    "pypdf==6.14.2" \
    "langchain-text-splitters==1.1.2" \
    "langchain-mcp-adapters==0.3.0" \
    "markitdown[all]==0.0.1" \
    # Necessário para `POST /api/references` (`UploadFile`/`File(...)`) funcionar
    # dentro da imagem `langchain/langgraph-api:3.11`, que não inclui essa
    # dependência. Sem esta linha o upload de referência quebra em runtime no
    # container real (apenas o `.venv` local tem a dep transitiva).
    "python-multipart==0.0.20" \
    # Necessário para o `http.app` (`webapp.py`) montar `FastAPI()` e os
    # routers usarem `APIRouter`/`UploadFile`/`File`. Achado empírico do
    # test-3 (`consolidate-http-routes-langgraph-task-test-3`): a imagem
    # `langchain/langgraph-api:3.11` traz `starlette` e `uvicorn`, mas NÃO
    # `fastapi` — sem essa linha, o container não consegue carregar o
    # `http.app` registrado em `langgraph.json`.
    "fastapi==0.139.0" \
    # Necessário para `src/infrastructure/auth/security.py` (hash/verificação
    # de senha via bcrypt), importado por `auth_router.py` no carregamento de
    # `webapp.py` (change `autenticacao-jwt-rotas-protegidas`, task-rest-1).
    # `psycopg`/`psycopg-pool` (usados por `auth/db.py`) já vêm transitivos do
    # checkpointer Postgres do LangGraph; `passlib`/`bcrypt` não.
    "passlib[bcrypt]==1.7.4" \
    "bcrypt==4.0.1"

ENV PYTHONPATH="/deps/backend:$PYTHONPATH"
ENV LANGGRAPH_STORE='{"type": "postgres", "url": "\${env:POSTGRES_URI}", "index": {"embed": "./src/models/ollama_embeddings.py:embed_texts", "dims": 1024, "fields": ["content"]}}'
ENV LANGGRAPH_CHECKPOINTER='{"type": "postgres", "url": "\${env:POSTGRES_URI}"}'
ENV LANGSERVE_GRAPHS='{"unified": "src.composition.graphs:unified", "agent": "src.composition.graphs:agent", "sdd_agent": "src.composition.graphs:sdd_agent", "assistant": "src.composition.graphs:assistant"}'
